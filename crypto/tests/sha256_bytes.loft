//
// sha256_b64: SHA-256 over RAW bytes (carried as base64), including non-UTF-8 input
// that `sha256(text)` cannot accept. KAT vectors via Python's hashlib + base64.
use crypto;

fn main() {
  // base64(sha256(b"")) — the empty digest
  assert(sha256_b64("") == "47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=",
    "sha256_b64 empty");
  // base64(sha256(bytes([0xff]))) — a single non-UTF-8 byte (the case that broke text_from_bytes)
  assert(sha256_b64("/w==") == "qBAK5qoZQNC2Y7sxzUZhQuu9vVGHExuS2TgYmHgy64k=",
    "sha256_b64 of 0xff (non-UTF-8 byte)");
  // base64(sha256(b"abc"))
  assert(sha256_b64("YWJj") == "ungWv48Bz+pBQUDeXa4iI7ADYaOWF3qctBD/YfIAFa0=",
    "sha256_b64 of abc");
  // via bytes_to_base64 — the path the protocol layer uses to hash a vector<u8>
  ff: vector<u8> = [0xff as u8];
  assert(sha256_b64(bytes_to_base64(ff)) == "qBAK5qoZQNC2Y7sxzUZhQuu9vVGHExuS2TgYmHgy64k=",
    "sha256_b64 via bytes_to_base64");

  println("crypto: sha256_b64 KATs pass (raw + non-UTF-8 bytes)");
}
