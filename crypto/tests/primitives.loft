// v0.3 primitives — end-to-end smoke tests through the loft FFI surface.
use crypto::(
  random_bytes_b64, base64_encode,
  ed25519_keypair, ed25519_sign, ed25519_verify,
  x25519_keypair, x25519_dh,
  hpke_seal, hpke_open,
  chacha20poly1305_seal, chacha20poly1305_open,
  aes256gcm_seal, aes256gcm_open,
  hkdf_extract_sha256, hkdf_expand_sha256
);

fn main() {
  // --- CSPRNG ---
  r1 = random_bytes_b64(32);
  r2 = random_bytes_b64(32);
  assert(r1.len() > 0, "random nonempty");
  assert(r1 != r2, "two random draws differ");

  // --- Ed25519 sign / verify ---
  kp = ed25519_keypair();
  assert(kp.sk.len() > 0, "ed25519 secret");
  assert(kp.pk.len() > 0, "ed25519 public");
  msg = base64_encode("hello loft");
  sig = ed25519_sign(kp.sk, msg);
  assert(sig.len() > 0, "ed25519 sign produced a signature");
  assert(ed25519_verify(kp.pk, msg, sig), "ed25519 verifies a valid signature");
  tampered = base64_encode("hello LOFT");
  assert(!ed25519_verify(kp.pk, tampered, sig), "ed25519 rejects a tampered message");

  // --- X25519 DH agreement ---
  alice = x25519_keypair();
  bob = x25519_keypair();
  s1 = x25519_dh(alice.sk, bob.pk);
  s2 = x25519_dh(bob.sk, alice.pk);
  assert(s1.len() > 0, "x25519 dh produced a shared secret");
  assert(s1 == s2, "x25519 dh agrees both directions");

  // --- HPKE seal / open (the group-key wrap primitive) ---
  rcpt = x25519_keypair();
  info = base64_encode("loft-zts/test/v1");
  aad = base64_encode("project=demo");
  kek = base64_encode("super secret project KEK");
  sealed = hpke_seal(rcpt.pk, info, aad, kek);
  assert(sealed.ct.len() > 0, "hpke produced ciphertext");
  opened = hpke_open(rcpt.sk, info, aad, sealed.enc, sealed.ct);
  assert(opened == kek, "hpke round-trips the wrapped key");

  // --- AEAD: ChaCha20-Poly1305 ---
  key = random_bytes_b64(32);
  nonce = random_bytes_b64(12);
  body = base64_encode("the quick brown fox");
  ct = chacha20poly1305_seal(key, nonce, aad, body);
  assert(ct.len() > 0, "chacha produced ciphertext");
  back = chacha20poly1305_open(key, nonce, aad, ct);
  assert(back == body, "chacha round-trips");
  bad = chacha20poly1305_open(key, nonce, base64_encode("other-aad"), ct);
  assert(bad.len() == 0, "chacha rejects wrong AAD");

  // --- AEAD: AES-256-GCM ---
  act = aes256gcm_seal(key, nonce, aad, body);
  assert(act.len() > 0, "aes produced ciphertext");
  aback = aes256gcm_open(key, nonce, aad, act);
  assert(aback == body, "aes round-trips");

  // --- HKDF over SHA-256 ---
  salt = base64_encode("saltsalt");
  ikm = random_bytes_b64(32);
  prk = hkdf_extract_sha256(salt, ikm);
  assert(prk.len() > 0, "hkdf extract produced a PRK");
  // 64 output bytes -> base64 STANDARD with padding = 88 chars.
  okm = hkdf_expand_sha256(prk, base64_encode("ctx"), 64);
  assert(okm.len() == 88, "hkdf expand produced 64 bytes (88 base64 chars)");

  print("loft-crypto v0.3 primitives: all assertions passed\n");
}
