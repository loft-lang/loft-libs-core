// Regex Phase 0: matches, find (inline patterns, thread-local cache).
use regex;

fn main() {
  // --- matches: presence / absence ---
  assert(regex::matches("[0-9]+", "abc123"), "digits present -> match");
  assert(!regex::matches("[0-9]+", "abcdef"), "no digits -> no match");

  // --- find: byte offset of first match, null when none ---
  assert(regex::find("[0-9]+", "abc123") == 3, "first digit at offset 3");
  assert(!regex::find("[0-9]+", "abcdef"), "no match -> null offset");
  assert(regex::find("[a-z]+", "  hi") == 2, "word starts at offset 2");

  // --- anchored pattern ---
  assert(regex::matches("^foo", "foobar"), "^foo matches foobar");
  assert(!regex::matches("^foo", "barfoo"), "^foo does not match barfoo");

  // --- invalid pattern fails safely (no raise) ---
  assert(!regex::matches("[unclosed", "anything"), "invalid pattern -> false");
  assert(!regex::find("(", "anything"), "invalid pattern -> null");

  // --- cache: many repeated calls with the same pattern stay correct ---
  ok = true;
  for _i in 0..200 {
    if !regex::matches("[a-z]+", "hello") {
      ok = false;
    }
  }
  assert(ok, "cached repeated calls remain correct");

  // --- split: yields pieces lazily through iterator<text> ---
  parts = "";
  count = 0;
  for piece in regex::split("[,;]", "a,b;c") {
    parts = "{parts}{piece}|";
    count = count + 1;
  }
  assert(count == 3, "split -> 3 pieces (got {count})");
  assert(parts == "a|b|c|", "split pieces = a|b|c| (got {parts})");
}

fn test_split_basic() {
  out = "";
  for p in regex::split(",", "a,b,c") {
    out = "{out}[{p}]";
  }
  assert(out == "[a][b][c]", "comma split (got {out})");
}

fn test_split_regex_separator() {
  out = "";
  n = 0;
  for p in regex::split(" +", "one  two   three") {
    out = "{out}{p}.";
    n = n + 1;
  }
  assert(n == 3, "whitespace-run split -> 3 (got {n})");
  assert(out == "one.two.three.", "split on ' +' (got {out})");
}

fn test_split_no_match() {
  n = 0;
  whole = "";
  for p in regex::split(",", "nocommas") {
    whole = p;
    n = n + 1;
  }
  assert(n == 1, "no separator -> 1 piece (got {n})");
  assert(whole == "nocommas", "whole string when no match");
}

fn test_split_trailing() {
  n = 0;
  for _p in regex::split(",", "a,") {
    n = n + 1;
  }
  assert(n == 2, "trailing separator -> 2 pieces incl empty (got {n})");
}

fn test_matches() {
  assert(regex::matches("[0-9]+", "abc123"), "digits present");
  assert(!regex::matches("[0-9]+", "xyz"), "no digits");
}

fn test_find_offset() {
  assert(regex::find("world", "hello world") == 6, "world at offset 6");
  assert(!regex::find("world", "hello there"), "no world -> null");
}

fn test_anchors() {
  assert(regex::matches("^foo$", "foo"), "exact foo");
  assert(!regex::matches("^foo$", "foobar"), "foobar not exact");
}

fn test_invalid_pattern_safe() {
  assert(!regex::matches("(", "x"), "invalid -> no match");
  assert(!regex::find("[", "x"), "invalid -> null find");
}
