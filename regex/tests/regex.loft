// Regex Phase 0: matches / find / split, as free functions AND text methods.
use regex;

fn main() {
  // --- matches: text method (subject.matches(pattern)) ---
  assert("abc123".matches("[0-9]+"), "digits present -> match");
  assert(!"abcdef".matches("[0-9]+"), "no digits -> no match");
  // ...and the free form (subject-first, via `both`)
  assert(regex::matches("abc123", "[0-9]+"), "free matches(input, pattern)");

  // --- find: free fn (pattern-first) AND regex_find method (subject-first) ---
  assert(regex::find("[0-9]+", "abc123") == 3, "free find -> offset 3");
  assert("abc123".regex_find("[0-9]+") == 3, "method regex_find -> offset 3");
  assert(!"abcdef".regex_find("[0-9]+"), "regex_find no match -> null");

  // --- anchored pattern ---
  assert("foobar".matches("^foo"), "^foo matches foobar");
  assert(!"barfoo".matches("^foo"), "^foo does not match barfoo");

  // --- invalid pattern fails safely (no raise) ---
  assert(!"anything".matches("[unclosed"), "invalid pattern -> false");
  assert(!"anything".regex_find("("), "invalid pattern -> null");

  // --- cache: many repeated calls with the same pattern stay correct ---
  ok = true;
  for _i in 0..200 {
    if !"hello".matches("[a-z]+") {
      ok = false;
    }
  }
  assert(ok, "cached repeated calls remain correct");

  // --- split: free fn (pattern-first) ---
  parts = "";
  count = 0;
  for piece in regex::split("[,;]", "a,b;c") {
    parts = "{parts}{piece}|";
    count = count + 1;
  }
  assert(count == 3, "free split -> 3 pieces (got {count})");
  assert(parts == "a|b|c|", "free split pieces = a|b|c| (got {parts})");

  // --- split: regex_split method (subject-first) ---
  mparts = "";
  for piece in "x,y,z".regex_split(",") {
    mparts = "{mparts}{piece}.";
  }
  assert(mparts == "x.y.z.", "method regex_split pieces (got {mparts})");
}

fn test_matches_method() {
  assert("abc123".matches("[0-9]+"), "digits present");
  assert(!"xyz".matches("[0-9]+"), "no digits");
}

fn test_regex_find_method() {
  assert("hello world".regex_find("world") == 6, "world at offset 6");
  assert(!"hello there".regex_find("world"), "no world -> null");
}

fn test_regex_split_method() {
  out = "";
  n = 0;
  for p in "one  two   three".regex_split(" +") {
    out = "{out}{p}.";
    n = n + 1;
  }
  assert(n == 3, "whitespace-run split -> 3 (got {n})");
  assert(out == "one.two.three.", "split on ' +' (got {out})");
}

fn test_free_functions() {
  // the pattern-first free forms still work
  assert(regex::find("[0-9]+", "abc123") == 3, "free find");
  assert(regex::matches("abc123", "[0-9]+"), "free matches subject-first");
  c = 0;
  for _p in regex::split(",", "a,b") {
    c = c + 1;
  }
  assert(c == 2, "free split count");
}

fn test_invalid_pattern_safe() {
  assert(!"x".matches("("), "invalid -> no match");
  assert(!"x".regex_find("["), "invalid -> null find");
}
