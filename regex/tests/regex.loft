// Regex Phase 0: compile, .is_match, .find.
use regex;

fn main() {
  // --- .is_match: presence / absence ---
  digits = regex::compile("[0-9]+");
  assert(digits.is_match("abc123"), "digits present -> match");
  assert(!digits.is_match("abcdef"), "no digits -> no match");

  // --- .find: byte offset of first match, null when none ---
  assert(digits.find("abc123") == 3, "first digit at offset 3");
  assert(!digits.find("abcdef"), "no match -> null offset");

  // --- compile once, reuse across inputs ---
  word = regex::compile("[a-z]+");
  assert(word.is_match("hello"), "lowercase word matches");
  assert(word.find("  hi") == 2, "word starts at offset 2");

  // --- anchored pattern ---
  start = regex::compile("^foo");
  assert(start.is_match("foobar"), "^foo matches foobar");
  assert(!start.is_match("barfoo"), "^foo does not match barfoo");

  // --- invalid pattern fails safely (no raise) ---
  bad = regex::compile("[unclosed");
  assert(!bad.is_match("anything"), "invalid pattern -> is_match false");
  assert(!bad.find("anything"), "invalid pattern -> find null");
}

fn test_is_match() {
  re = regex::compile("[0-9]+");
  assert(re.is_match("abc123"), "digits present");
  assert(!re.is_match("xyz"), "no digits");
}

fn test_find_offset() {
  re = regex::compile("world");
  assert(re.find("hello world") == 6, "world at offset 6");
  assert(!re.find("hello there"), "no world -> null");
}

fn test_anchors() {
  re = regex::compile("^foo$");
  assert(re.is_match("foo"), "exact foo");
  assert(!re.is_match("foobar"), "foobar not exact");
}

fn test_invalid_pattern_safe() {
  re = regex::compile("(");
  assert(!re.is_match("x"), "invalid -> no match");
  assert(!re.find("x"), "invalid -> null find");
}
