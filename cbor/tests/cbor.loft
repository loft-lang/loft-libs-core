// CBOR encoder — RFC 8949 Appendix A vectors (canonical, byte-identical).
use cbor;

fn bytes_eq(a: vector<u8>, b: vector<u8>) -> boolean {
  if len(a) != len(b) { return false; }
  for i in 0..len(a) { if a[i] != b[i] { return false; } }
  return true;
}

fn main() {
  // unsigned integers (major 0), shortest-form heads
  assert(bytes_eq(encode(CInt { value: 0 }),    [0x00 as u8]), "uint 0");
  assert(bytes_eq(encode(CInt { value: 23 }),   [0x17 as u8]), "uint 23");
  assert(bytes_eq(encode(CInt { value: 24 }),   [0x18 as u8, 0x18 as u8]), "uint 24");
  assert(bytes_eq(encode(CInt { value: 1000 }), [0x19 as u8, 0x03 as u8, 0xe8 as u8]), "uint 1000");
  assert(bytes_eq(encode(CInt { value: 1000000 }),
    [0x1a as u8, 0x00 as u8, 0x0f as u8, 0x42 as u8, 0x40 as u8]), "uint 1000000");

  // negative integers (major 1)
  assert(bytes_eq(encode(CInt { value: 0 - 1 }),   [0x20 as u8]), "negint -1");
  assert(bytes_eq(encode(CInt { value: 0 - 100 }), [0x38 as u8, 0x63 as u8]), "negint -100");

  // simple values (major 7)
  assert(bytes_eq(encode(CBool { value: false }), [0xf4 as u8]), "false");
  assert(bytes_eq(encode(CBool { value: true }),  [0xf5 as u8]), "true");
  assert(bytes_eq(encode(CNull), [0xf6 as u8]), "null");

  // text string (major 3) + byte string (major 2)
  assert(bytes_eq(encode(CText { value: "IETF" }),
    [0x64 as u8, 0x49 as u8, 0x45 as u8, 0x54 as u8, 0x46 as u8]), "text IETF");
  assert(bytes_eq(encode(CBytes { value: [1 as u8, 2 as u8, 3 as u8, 4 as u8] }),
    [0x44 as u8, 0x01 as u8, 0x02 as u8, 0x03 as u8, 0x04 as u8]), "bytes 01020304");

  // array (major 4) + map (major 5), nesting
  assert(bytes_eq(encode(CArray { items: [CInt { value: 1 }, CInt { value: 2 }, CInt { value: 3 }] }),
    [0x83 as u8, 0x01 as u8, 0x02 as u8, 0x03 as u8]), "array 1 2 3");
  assert(bytes_eq(
    encode(CMap { entries: [
      CborEntry { key: CInt { value: 1 }, value: CInt { value: 2 } },
      CborEntry { key: CInt { value: 3 }, value: CInt { value: 4 } } ] }),
    [0xa2 as u8, 0x01 as u8, 0x02 as u8, 0x03 as u8, 0x04 as u8]), "map 1to2 3to4");

  // canonical map-key ordering (RFC 8949 §4.2.1): out-of-order keys encode sorted
  assert(bytes_eq(
    encode(CMap { entries: [
      CborEntry { key: CInt { value: 3 }, value: CInt { value: 4 } },
      CborEntry { key: CInt { value: 1 }, value: CInt { value: 2 } } ] }),
    [0xa2 as u8, 0x01 as u8, 0x02 as u8, 0x03 as u8, 0x04 as u8]), "map canonical reorder");
  // mixed-length keys sort BYTEWISE: 10 (0x0a) < 24 (0x18 18) < 100 (0x18 64)
  assert(bytes_eq(
    encode(CMap { entries: [
      CborEntry { key: CInt { value: 100 }, value: CInt { value: 0 } },
      CborEntry { key: CInt { value: 10 },  value: CInt { value: 1 } },
      CborEntry { key: CInt { value: 24 },  value: CInt { value: 2 } } ] }),
    [0xa3 as u8, 0x0a as u8, 0x01 as u8, 0x18 as u8, 0x18 as u8, 0x02 as u8,
     0x18 as u8, 0x64 as u8, 0x00 as u8]), "map canonical mixed-length");

  println("cbor: all RFC 8949 vectors pass");
}
